    <div class="parva-header">
      <div class="parva-num">12</div>
      <div class="parva-title-wrap">
        <div class="parva-badge" style="background:rgba(107,26,26,0.1);color:#aaa;">👑 PREMIUM · ★ LARGEST PARVA</div>
        <div class="parva-title" data-lang="en">Shanti Parva — The Teachings of Bhishma</div>
        <div class="parva-title" data-lang="hi" style="display:none">Shanti Parva — The Teachings of Bhishma</div>
        <div class="parva-title" data-lang="kn" style="display:none">Shanti Parva — The Teachings of Bhishma</div>
