<script>
var parvas = [
  {n:1,name:'Adi Parva',free:true},{n:2,name:'Sabha Parva',free:true},{n:3,name:'Vana Parva',free:true},
  {n:4,name:'Virata Parva',free:false},{n:5,name:'Udyoga Parva',free:false},{n:6,name:'Bhishma Parva',free:false},
  {n:7,name:'Drona Parva',free:false},{n:8,name:'Karna Parva',free:false},{n:9,name:'Shalya Parva',free:false},
  {n:10,name:'Sauptika Parva',free:false},{n:11,name:'Stri Parva',free:false},{n:12,name:'Shanti Parva',free:false},
  {n:13,name:'Anushasana Parva',free:false},{n:14,name:'Ashvamedhika Parva',free:false},{n:15,name:'Ashramavasika Parva',free:false},
  {n:16,name:'Mausala Parva',free:false},{n:17,name:'Mahaprasthanika Parva',free:false},{n:18,name:'Svargarohana Parva',free:false}
];

// Build progress bar
var track = document.getElementById('progressTrack');
parvas.forEach(function(p) {
  var div = document.createElement('div');
  div.className = 'progress-parva ' + (p.free ? 'free' : 'locked');
  div.setAttribute('data-name', p.n + '. ' + p.name);
  div.onclick = (function(pn){ return function() {
    var el = document.getElementById('parva-' + pn);
    if(el) el.scrollIntoView({behavior:'smooth'});
  }; })(p.n);
  track.appendChild(div);
});

// Build parva nav
var navGrid = document.getElementById('parvaNavGrid');
parvas.forEach(function(p) {
  var a = document.createElement('a');
  a.className = 'parva-nav-item';
  a.href = '#parva-' + p.n;
  a.innerHTML = '<span class="lock-icon">' + (p.free ? '📖' : '🔒') + '</span>' + p.n + '. ' + p.name;
  navGrid.appendChild(a);
});

// Language switcher
function setLang(lang, btn) {
  document.querySelectorAll('.lang-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  // Toggle parva titles
  document.querySelectorAll('.parva-title').forEach(function(el) {
    el.style.display = el.dataset.lang === lang ? 'block' : 'none';
  });
  // Toggle story text divs and h3s
  var allLangs = ['en','hi','kn','te','ta','ml','gu'];
  allLangs.forEach(function(l) {
    document.querySelectorAll('[data-lang="' + l + '"]').forEach(function(el) {
      el.style.display = (l === lang) ? '' : 'none';
    });
  });
}

// Init — show English by default
document.querySelectorAll('[data-lang]').forEach(function(el) {
  if (el.dataset.lang !== 'en') el.style.display = 'none';
});
</script>

