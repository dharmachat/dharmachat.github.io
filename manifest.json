/* LANG SWITCHER */
.lang-bar{background:var(--maroon-dk);border-bottom:1px solid rgba(212,160,23,0.15);padding:14px 24px;position:sticky;top:64px;z-index:100}
.lang-inner{max-width:900px;margin:0 auto;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.lang-label{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.1em;color:rgba(255,255,255,0.35);margin-right:4px;flex-shrink:0}
.lang-btn{font-family:'Cinzel',serif;font-size:11px;letter-spacing:.04em;padding:6px 14px;border-radius:50px;border:1px solid rgba(212,160,23,0.2);background:transparent;color:rgba(255,255,255,0.45);cursor:pointer;transition:all .2s;flex-shrink:0}
.lang-btn:hover{background:rgba(212,160,23,0.1);color:var(--gold-lt)}
.lang-btn.active{background:rgba(212,160,23,0.2);border-color:rgba(212,160,23,0.5);color:var(--gold-lt)}

/* PROGRESS */
.progress-bar{max-width:900px;margin:0 auto;padding:20px 24px 0}
.progress-track{display:flex;gap:4px;align-items:center}
.progress-parva{height:4px;border-radius:2px;flex:1;background:rgba(107,26,26,0.15);cursor:pointer;transition:all .2s;position:relative}
.progress-parva.free{background:linear-gradient(90deg,var(--saffron),var(--gold))}
.progress-parva.locked{background:rgba(107,26,26,0.15)}
.progress-parva:hover::after{content:attr(data-name);position:absolute;bottom:10px;left:50%;transform:translateX(-50%);background:var(--maroon-dk);color:var(--gold-lt);font-family:'Cinzel',serif;font-size:9px;padding:3px 8px;border-radius:4px;white-space:nowrap;pointer-events:none;letter-spacing:.04em}

/* MAIN LAYOUT */
.main{max-width:900px;margin:0 auto;padding:40px 24px 80px}

/* PARVA */
.parva{margin-bottom:64px;position:relative}
.parva-header{display:flex;align-items:flex-start;gap:20px;margin-bottom:28px;padding-bottom:20px;border-bottom:2px solid rgba(212,160,23,0.15)}
.parva-num{font-family:'Cinzel Decorative',serif;font-size:52px;color:rgba(212,160,23,0.2);line-height:1;flex-shrink:0;min-width:60px}
.parva-title-wrap{}
.parva-badge{display:inline-block;font-family:'Cinzel',serif;font-size:9px;letter-spacing:.12em;padding:3px 10px;border-radius:20px;background:rgba(232,97,26,0.1);color:var(--saffron);margin-bottom:8px}
.parva-title{font-family:'Cinzel',serif;font-size:26px;color:var(--maroon-dk);font-weight:700;line-height:1.2;margin-bottom:4px}
.parva-sanskrit{font-family:'EB Garamond',serif;font-style:italic;font-size:18px;color:var(--gold-dk)}
.parva-meta{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.08em;color:#bbb;margin-top:6px}

/* STORY */
.story{background:white;border-radius:16px;border:1px solid rgba(107,26,26,0.07);box-shadow:0 2px 12px rgba(107,26,26,0.05);padding:28px;margin-bottom:20px}
.story-label{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.1em;color:var(--saffron);margin-bottom:12px}
.story h3{font-family:'Cinzel',serif;font-size:18px;color:var(--maroon-dk);font-weight:700;margin-bottom:14px;line-height:1.4}
.story-text{font-family:'EB Garamond',serif;font-size:18px;line-height:1.85;color:var(--text-dark)}
.story-text p{margin-bottom:16px}
.story-text strong{color:var(--maroon-dk)}
.shloka-block{background:linear-gradient(135deg,rgba(62,0,0,0.03),rgba(212,160,23,0.06));border:1px solid rgba(212,160,23,0.2);border-radius:12px;padding:22px 26px;margin:20px 0;text-align:center}
.shloka-sanskrit{font-family:'EB Garamond',serif;font-size:20px;color:var(--maroon-dk);line-height:1.7;margin-bottom:6px;font-weight:500}
.shloka-meaning{font-family:'EB Garamond',serif;font-style:italic;font-size:16px;color:var(--text-mid);line-height:1.6;margin-bottom:6px}
.shloka-source{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.08em;color:var(--gold-dk)}

/* PAYWALL */
.parva.locked-parva{position:relative}
.parva.locked-parva .parva-content{filter:blur(5px);user-select:none;pointer-events:none;max-height:200px;overflow:hidden}
.paywall-overlay{position:absolute;bottom:0;left:0;right:0;z-index:10;background:linear-gradient(to top,var(--cream) 50%,transparent 100%);padding:0 0 24px;text-align:center}
