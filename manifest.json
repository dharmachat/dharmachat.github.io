.hero h1{font-family:'Cinzel Decorative',serif;font-size:clamp(28px,5vw,52px);color:var(--white);line-height:1.15;margin-bottom:16px;text-shadow:0 2px 20px rgba(0,0,0,0.4)}
.hero h1 span{color:var(--gold-lt)}
.hero-sub{font-family:'EB Garamond',serif;font-style:italic;font-size:19px;color:rgba(255,255,255,0.65);max-width:700px;margin:0 auto 16px;line-height:1.7}
.hero-meta{font-family:'Cinzel',serif;font-size:11px;letter-spacing:.1em;color:rgba(255,255,255,0.4);margin-bottom:36px}
.hero-stats{display:flex;gap:40px;justify-content:center;flex-wrap:wrap;margin-bottom:36px}
