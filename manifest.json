.paywall-box p{font-family:'EB Garamond',serif;font-style:italic;font-size:16px;color:rgba(255,255,255,0.6);margin-bottom:20px;line-height:1.6}
.paywall-features{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-bottom:24px}
.paywall-feature{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.06em;color:var(--gold-lt);background:rgba(212,160,23,0.1);border:1px solid rgba(212,160,23,0.2);border-radius:50px;padding:5px 14px}
.btn-unlock{display:inline-block;padding:14px 36px;background:linear-gradient(135deg,var(--saffron),var(--gold));border:none;border-radius:50px;color:white;font-family:'Cinzel',serif;font-size:14px;font-weight:700;letter-spacing:.06em;cursor:pointer;text-decoration:none;box-shadow:0 4px 20px rgba(232,97,26,0.4);transition:all .2s;margin-bottom:10px;display:block;width:fit-content;margin:0 auto 12px}
.btn-unlock:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(232,97,26,0.5)}
.paywall-note{font-family:'Cinzel',serif;font-size:10px;color:rgba(255,255,255,0.3);letter-spacing:.06em}

/* DIVIDER */
.parva-divider{text-align:center;margin:48px 0;display:flex;align-items:center;gap:16px}
.parva-divider::before,.parva-divider::after{content:'';flex:1;height:1px;background:rgba(107,26,26,0.1)}
.parva-divider span{font-family:'EB Garamond',serif;font-size:24px;color:rgba(212,160,23,0.3)}

/* PARVA NAV */
.parva-nav{background:white;border-radius:16px;border:1px solid rgba(107,26,26,0.08);padding:24px;margin-bottom:40px}
.parva-nav h3{font-family:'Cinzel',serif;font-size:13px;letter-spacing:.1em;color:var(--maroon-dk);margin-bottom:16px;font-weight:700}
.parva-nav-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
@media(max-width:600px){.parva-nav-grid{grid-template-columns:repeat(2,1fr)}}
.parva-nav-item{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.04em;padding:8px 10px;border-radius:8px;border:1px solid rgba(107,26,26,0.08);color:var(--text-mid);cursor:pointer;transition:all .2s;text-decoration:none;display:flex;align-items:center;gap:6px;line-height:1.3}
.parva-nav-item:hover{background:rgba(107,26,26,0.04);border-color:rgba(212,160,23,0.25);color:var(--maroon)}
.parva-nav-item.locked-item{color:#ccc;cursor:default}
.parva-nav-item.locked-item:hover{background:none;border-color:rgba(107,26,26,0.08)}
.lock-icon{font-size:10px;flex-shrink:0}

/* FOOTER */
footer{background:var(--maroon-dk);padding:40px 24px;text-align:center}
footer p{font-family:'Cinzel',serif;font-size:11px;color:rgba(255,255,255,0.25);letter-spacing:.05em}
footer a{color:rgba(240,192,64,0.5);text-decoration:none;margin:0 10px}

@media(max-width:600px){
  nav .nav-right .nav-link{display:none}
  .parva-header{flex-direction:column;gap:10px}
  .parva-num{font-size:36px}
  .parva-title{font-size:20px}
}
</style>
</head>
