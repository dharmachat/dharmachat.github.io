  <!-- PARVA 1 — ADI PARVA (FREE) -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="parva" id="parva-1">
    <div class="parva-header">
      <div class="parva-num">01</div>
      <div class="parva-title-wrap">
        <div class="parva-badge">FREE PREVIEW</div>
        <div class="parva-title" data-lang="en">Adi Parva — The Book of Beginnings</div>
