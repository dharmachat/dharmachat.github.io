.logo-wrap img{width:36px;height:36px;border-radius:50%;object-fit:cover}
.logo-name{font-family:'Cinzel Decorative',serif;font-size:18px;color:var(--gold-lt)}
.nav-right{display:flex;align-items:center;gap:12px}
.nav-link{font-family:'Cinzel',serif;font-size:12px;color:rgba(240,192,64,0.65);text-decoration:none;letter-spacing:.06em}
.nav-link:hover{color:var(--gold-lt)}
.btn-upgrade{background:linear-gradient(135deg,var(--gold),var(--saffron));color:white;font-family:'Cinzel',serif;font-size:12px;font-weight:700;padding:8px 20px;border-radius:50px;text-decoration:none;letter-spacing:.05em;box-shadow:0 4px 12px rgba(212,160,23,0.4)}

/* HERO */
.hero{background:linear-gradient(160deg,var(--maroon-dk) 0%,#4A0A0A 40%,#7A1A00 70%,#3E0000 100%);padding:80px 24px 60px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='120' height='120' viewBox='0 0 120 120' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='60' cy='60' r='58' fill='none' stroke='%23D4A017' stroke-opacity='0.06' stroke-width='1'/%3E%3Ccircle cx='60' cy='60' r='40' fill='none' stroke='%23D4A017' stroke-opacity='0.04' stroke-width='1'/%3E%3C/svg%3E") repeat;opacity:.6}
.hero::after{content:'⚔️';position:absolute;right:-20px;top:50%;transform:translateY(-50%);font-size:400px;opacity:.04;pointer-events:none}
