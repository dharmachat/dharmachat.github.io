<style>
  :root{--saffron:#E8611A;--saffron-lt:#F5832A;--gold:#D4A017;--gold-lt:#F0C040;--maroon:#6B1A1A;--maroon-dk:#3E0000;--cream:#FDF6E3;--white:#FFFFFF}
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Noto Sans',sans-serif;background:var(--cream);color:var(--maroon-dk)}

  /* NAV */
  nav{background:var(--maroon-dk);border-bottom:1px solid rgba(212,160,23,0.25);padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;}
  .logo-wrap{display:flex;align-items:center;gap:10px;text-decoration:none;}
  .logo-wrap img{width:36px;height:36px;border-radius:50%;object-fit:cover;}
  .logo-name{font-family:'Cinzel Decorative',serif;font-size:18px;color:var(--gold-lt);}
  .nav-right{display:flex;align-items:center;gap:16px;}
  .nav-link{font-family:'Cinzel',serif;font-size:12px;color:rgba(240,192,64,0.7);text-decoration:none;letter-spacing:.05em;}
  .nav-link:hover{color:var(--gold-lt);}
  .btn-try{background:linear-gradient(135deg,var(--saffron),var(--gold));color:white;font-family:'Cinzel',serif;font-size:12px;font-weight:700;padding:8px 20px;border-radius:50px;text-decoration:none;letter-spacing:.05em;}

  /* HERO */
  .hero{background:linear-gradient(160deg,var(--maroon-dk),#5A0A0A);padding:80px 24px 60px;text-align:center;}
  .hero-tag{display:inline-block;background:rgba(212,160,23,0.15);border:1px solid rgba(212,160,23,0.3);color:var(--gold-lt);font-family:'Cinzel',serif;font-size:11px;letter-spacing:.12em;padding:5px 16px;border-radius:20px;margin-bottom:20px;}
  .hero h1{font-family:'Cinzel Decorative',serif;font-size:clamp(26px,5vw,44px);color:var(--white);margin-bottom:16px;line-height:1.2;}
  .hero h1 span{color:var(--gold-lt);}
  .hero p{font-family:'EB Garamond',serif;font-style:italic;font-size:18px;color:rgba(255,255,255,0.65);max-width:560px;margin:0 auto 32px;line-height:1.7;}
  .search-wrap{max-width:500px;margin:0 auto;position:relative;}
  .search-input{width:100%;padding:15px 50px 15px 20px;border-radius:50px;border:1px solid rgba(212,160,23,0.3);background:rgba(255,255,255,0.08);color:white;font-family:'Noto Sans',sans-serif;font-size:14px;outline:none;}
  .search-input::placeholder{color:rgba(255,255,255,0.35);}

  /* FILTERS */
  .filters{background:white;border-bottom:1px solid rgba(107,26,26,0.08);padding:20px 24px;position:sticky;top:0;z-index:10;}
  .filters-inner{max-width:1100px;margin:0 auto;display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
  .filter-btn{font-family:'Cinzel',serif;font-size:11px;letter-spacing:.06em;padding:7px 18px;border-radius:50px;border:1px solid rgba(107,26,26,0.2);background:transparent;color:var(--maroon);cursor:pointer;transition:all .2s;}
  .filter-btn:hover,.filter-btn.active{background:var(--maroon-dk);color:var(--gold-lt);border-color:var(--maroon-dk);}
  .filter-label{font-family:'Cinzel',serif;font-size:11px;color:#999;letter-spacing:.06em;margin-right:4px;}

  /* LESSONS GRID */
  .lessons-section{max-width:1100px;margin:0 auto;padding:60px 24px;}
  .section-heading{font-family:'Cinzel',serif;font-size:13px;letter-spacing:.12em;color:var(--saffron);margin-bottom:24px;display:flex;align-items:center;gap:12px;}
  .section-heading::after{content:'';flex:1;height:1px;background:rgba(107,26,26,0.1);}
  .lessons-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;margin-bottom:60px;}
  .lesson-card{background:white;border-radius:16px;border:1px solid rgba(107,26,26,0.08);box-shadow:0 2px 16px rgba(107,26,26,0.06);overflow:hidden;transition:all .25s;display:flex;flex-direction:column;}
  .lesson-card:hover{transform:translateY(-4px);box-shadow:0 8px 32px rgba(107,26,26,0.12);}
  .card-top{padding:24px 24px 16px;flex:1;}
  .card-category{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.1em;padding:3px 12px;border-radius:20px;display:inline-block;margin-bottom:12px;}
  .cat-beginner{background:rgba(232,97,26,0.1);color:var(--saffron);}
  .cat-gita{background:rgba(212,160,23,0.12);color:#9A7000;}
  .cat-ramayana{background:rgba(107,26,26,0.08);color:var(--maroon);}
  .cat-mahabharata{background:rgba(62,0,0,0.08);color:var(--maroon-dk);}
  .cat-upanishad{background:rgba(0,100,80,0.08);color:#005040;}
  .cat-life{background:rgba(0,60,120,0.08);color:#003478;}
  .card-title{font-family:'Cinzel',serif;font-size:16px;color:var(--maroon-dk);margin-bottom:10px;font-weight:700;line-height:1.4;}
  .card-summary{font-family:'EB Garamond',serif;font-style:italic;font-size:15px;color:#666;line-height:1.7;margin-bottom:16px;}
  .card-shloka{background:rgba(212,160,23,0.06);border-left:3px solid rgba(212,160,23,0.4);padding:10px 14px;border-radius:0 8px 8px 0;margin-bottom:16px;}
  .card-shloka-text{font-family:'EB Garamond',serif;font-size:14px;color:var(--maroon);font-style:italic;line-height:1.6;}
  .card-shloka-source{font-family:'Cinzel',serif;font-size:10px;color:var(--gold);letter-spacing:.06em;margin-top:4px;}
  .card-bottom{padding:16px 24px;border-top:1px solid rgba(107,26,26,0.06);display:flex;gap:10px;}
  .btn-read{flex:1;padding:10px;border-radius:50px;font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:.06em;cursor:pointer;transition:all .2s;text-align:center;text-decoration:none;border:1px solid var(--maroon);color:var(--maroon);background:transparent;}
  .btn-read:hover{background:var(--maroon);color:white;}
  .btn-ai{flex:1;padding:10px;border-radius:50px;font-family:'Cinzel',serif;font-size:11px;font-weight:700;letter-spacing:.06em;cursor:pointer;transition:all .2s;text-align:center;text-decoration:none;background:linear-gradient(135deg,var(--saffron),var(--gold));color:white;border:none;}
  .btn-ai:hover{opacity:.9;transform:translateY(-1px);}
  .difficulty{display:flex;align-items:center;gap:4px;font-family:'Cinzel',serif;font-size:10px;color:#999;letter-spacing:.04em;margin-bottom:10px;}
  .dot{width:6px;height:6px;border-radius:50%;background:#ddd;}
  .dot.filled{background:var(--saffron);}

  /* FOOTER */
  footer{background:var(--maroon-dk);padding:40px 24px;text-align:center;margin-top:60px;}
  footer p{font-size:12px;color:rgba(255,255,255,0.4);font-family:'Cinzel',serif;letter-spacing:.05em;}
  footer a{color:rgba(240,192,64,0.6);text-decoration:none;margin:0 12px;}

  @media(max-width:600px){.lessons-grid{grid-template-columns:1fr;}.filters-inner{gap:8px;}.hero h1{font-size:26px;}}
</style>
</head>
