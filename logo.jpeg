<script>
let activeFilter = 'all';

function setFilter(cat, btn) {
  activeFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  filterLessons();
}

function filterLessons() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const cards = document.querySelectorAll('.lesson-card');
  const headings = {
    beginner: document.getElementById('heading-beginner'),
    gita: document.getElementById('heading-gita'),
    ramayana: document.getElementById('heading-ramayana'),
    mahabharata: document.getElementById('heading-mahabharata'),
    upanishad: document.getElementById('heading-upanishad'),
    life: document.getElementById('heading-life')
  };
  const grids = {
    beginner: document.getElementById('grid-beginner'),
    gita: document.getElementById('grid-gita'),
    ramayana: document.getElementById('grid-ramayana'),
    mahabharata: document.getElementById('grid-mahabharata'),
    upanishad: document.getElementById('grid-upanishad'),
    life: document.getElementById('grid-life')
  };

  let visibleBySection = {beginner:0, gita:0, ramayana:0, mahabharata:0, upanishad:0, life:0};

  cards.forEach(card => {
    const cat = card.dataset.category;
    const keywords = card.dataset.keywords || '';
    const title = card.querySelector('.card-title').textContent.toLowerCase();
    const summary = card.querySelector('.card-summary').textContent.toLowerCase();
    const matchFilter = activeFilter === 'all' || cat === activeFilter;
    const matchSearch = !q || title.includes(q) || keywords.includes(q) || summary.includes(q);
    const show = matchFilter && matchSearch;
    card.style.display = show ? 'flex' : 'none';
    if (show) visibleBySection[cat]++;
  });

  // Show/hide section headings based on visible cards
  Object.keys(headings).forEach(cat => {
    const show = visibleBySection[cat] > 0;
    if (headings[cat]) headings[cat].style.display = show ? 'flex' : 'none';
    if (grids[cat]) grids[cat].style.display = show ? 'grid' : 'none';
  });
}
</script>
<script src="dc-premium-unlock.js?v=3"></script>
