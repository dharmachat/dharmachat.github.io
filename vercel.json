{
  "version": 2,
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/chat$",
      "dest": "/chat.html"
    },
    {
      "src": "^/premium$",
      "dest": "/premium.html"
    },
    {
      "src": "^/privacy$",
      "dest": "/privacy.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
