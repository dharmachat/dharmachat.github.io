<script>
function toggleFaq(btn){
  const a = btn.nextElementSibling;
  const icon = btn.querySelector('.faq-icon');
  a.style.display = a.style.display === 'none' ? 'block' : 'none';
  icon.textContent = a.style.display === 'none' ? '+' : '−';
}
function shareWA(){
  window.open('https://wa.me/?text=' + encodeURIComponent(document.title + ' — ' + window.location.href), '_blank');
}
function copyLink(){
  navigator.clipboard.writeText(window.location.href).then(()=>{
    const btn = document.querySelector('.share-cp');
    btn.textContent = '✓ Copied!';
    setTimeout(()=>{btn.textContent='🔗 Copy Link';}, 2000);
  });
}
function nlSub(){
  const e = document.getElementById('nlEmail');
  if(!e.value||!e.value.includes('@')){e.style.borderColor='rgba(232,97,26,0.6)';return;}
  e.style.borderColor='rgba(212,160,23,0.5)';
  e.value='';
  e.placeholder='Thank you! 🙏 Dharmic wisdom is on its way.';
}
</script>
<script type="module">
