import { getAuth, signInWithPopup, GoogleAuthProvider, onAuthStateChanged, signOut as fbSignOut } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js';
const _app = initializeApp({apiKey:"AIzaSyDvw26WTzNRsBBgjXG9At60pN8ApDvPB7o",authDomain:"dharmachat-cc71d.firebaseapp.com",projectId:"dharmachat-cc71d",storageBucket:"dharmachat-cc71d.firebasestorage.app",messagingSenderId:"718284855701",appId:"1:718284855701:web:d7ef64292cd48ffdf13e9c"});
const _auth = getAuth(_app); const _provider = new GoogleAuthProvider();
function updateNav(user){const n=document.getElementById('navAuth');if(!n)return;if(user){n.innerHTML='<div style="display:flex;align-items:center;gap:10px;"><img src="'+(user.photoURL||'')+'" style="width:32px;height:32px;border-radius:50%;object-fit:cover;border:2px solid rgba(212,160,23,0.4);" onerror="this.style.display=\'none\'"/><span style="font-family:Cinzel,serif;font-size:12px;color:rgba(240,192,64,0.9);">'+(user.displayName?.split(' ')[0]||'Devotee')+'</span><button onclick="window.__so()" style="font-family:Cinzel,serif;font-size:10px;color:rgba(255,255,255,0.4);background:none;border:1px solid rgba(255,255,255,0.15);border-radius:20px;padding:4px 10px;cursor:pointer;">Sign Out</button></div>';}else{n.innerHTML='<button onclick="window.__si()" style="display:flex;align-items:center;gap:8px;padding:7px 16px;background:white;border:none;border-radius:50px;font-family:Noto Sans,sans-serif;font-size:12px;color:#333;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.2);"><svg width="14" height="14" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>Sign In</button>';}}
onAuthStateChanged(_auth,(user)=>{updateNav(user);});
window.__si=async function(){try{await signInWithPopup(_auth,_provider);}catch(e){}};
window.__so=async function(){await fbSignOut(_auth);localStorage.removeItem('dc_guest');location.reload();};
</script>
